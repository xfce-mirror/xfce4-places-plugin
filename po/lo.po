#: panel-plugin/places.desktop.in:4 panel-plugin/cfg.c:100
#: panel-plugin/cfg.c:195 panel-plugin/cfg.c:396
msgid "Places"
msgstr "ສະຖານທີ່"

#: panel-plugin/places.desktop.in:5
msgid "Access folders, documents, and removable media"
msgstr "ເຂົ້າເຖິງໂຟນເດີ, ເອກະສານ ແລະ ສື່ທີ່ຖອດອອກໄດ້"

#. Trash
#: panel-plugin/model_system.c:151
msgid "Trash"
msgstr "ຖັງຂີ້ເຫຍື້ອ"

#: panel-plugin/model_system.c:188
msgid "Desktop"
msgstr "ໜ້າຈໍ"

#. File System (/)
#: panel-plugin/model_system.c:204
msgid "File System"
msgstr "ລະບົບໄຟລ໌"

#. TRANSLATORS: this will result in "<path> on <hostname>"
#: panel-plugin/model_user.c:256
#, c-format
msgid "%s on %s"
msgstr "%s ຢູ່ %s"

#: panel-plugin/model_volumes.c:71
#, c-format
msgid "Failed to eject \"%s\""
msgstr "ບໍ່ສາມາດດັນ \"%s\" ອອກໄດ້"

#: panel-plugin/model_volumes.c:120
#, c-format
msgid "Failed to unmount \"%s\""
msgstr "ບໍ່ສາມາດຍົກເລີກການເຊື່ອມຕໍ່ \"%s\" ໄດ້"

#: panel-plugin/model_volumes.c:170 panel-plugin/model_volumes.c:193
#, c-format
msgid "Failed to mount \"%s\""
msgstr "ບໍ່ສາມາດເຊື່ອມຕໍ່ \"%s\" ໄດ້"

#: panel-plugin/model_volumes.c:478
msgid "Mount and Open"
msgstr "ເຊື່ອມຕໍ່ ແລະ ເປີດ"

#: panel-plugin/model_volumes.c:491
msgid "Mount"
msgstr "ເຊື່ອມຕໍ່"

#: panel-plugin/model_volumes.c:511
msgid "Eject"
msgstr "ດັນອອກ"

#: panel-plugin/model_volumes.c:521
msgid "Unmount"
msgstr "ຍົກເລີກການເຊື່ອມຕໍ່"

#. TRANSLATORS: Please use the same translation here as in Thunar
#: panel-plugin/model_volumes_notify.c:128
msgid "Unmounting device"
msgstr "ກຳລັງຍົກເລີກການເຊື່ອມຕໍ່ອຸປະກອນ"

#. TRANSLATORS: Please use the same translation here as in Thunar
#: panel-plugin/model_volumes_notify.c:131
#, c-format
msgid ""
"The device \"%s\" is being unmounted by the system. Please do not remove the"
" media or disconnect the drive"
msgstr "ລະບົບກຳລັງຍົກເລີກການເຊື່ອມຕໍ່ອຸປະກອນ \"%s\". ກະລຸນາຢ່າຟ້າວຖອດສື່ ຫຼື ຕັດການເຊື່ອມຕໍ່ໄດຣຟ໌"

#. TRANSLATORS: Please use the same translation here as in Thunar
#: panel-plugin/model_volumes_notify.c:138
#: panel-plugin/model_volumes_notify.c:262
msgid "Writing data to device"
msgstr "ກຳລັງຂຽນຂໍ້ມູນລົງໃນອຸປະກອນ"

#. TRANSLATORS: Please use the same translation here as in Thunar
#: panel-plugin/model_volumes_notify.c:141
#: panel-plugin/model_volumes_notify.c:265
#, c-format
msgid ""
"There is data that needs to be written to the device \"%s\" before it can be"
" removed. Please do not remove the media or disconnect the drive"
msgstr "ມີຂໍ້ມູນທີ່ຈຳເປັນຕ້ອງຂຽນລົງໃນອຸປະກອນ \"%s\" ກ່ອນທີ່ຈະຖອດອອກໄດ້. ກະລຸນາຢ່າຟ້າວຖອດສື່ ຫຼື ຕັດການເຊື່ອມຕໍ່ໄດຣຟ໌"

#. TRANSLATORS: Please use the same translation here as in Thunar
#: panel-plugin/model_volumes_notify.c:253
msgid "Ejecting device"
msgstr "ກຳລັງດັນອຸປະກອນອອກ"

#. TRANSLATORS: Please use the same translation here as in Thunar
#: panel-plugin/model_volumes_notify.c:256
#, c-format
msgid "The device \"%s\" is being ejected. This may take some time"
msgstr "ກຳລັງດັນອຸປະກອນ \"%s\" ອອກ. ອາດໃຊ້ເວລາຄາວໜຶ່ງ"

